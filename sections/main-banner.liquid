<section style="position:relative;min-height:100svh;background:#050510;overflow:hidden;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:80px 24px;">
  <div class="vanta-glow" style="position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle, rgba(0,102,255,0.18) 0%, rgba(0,212,255,0.04) 50%, transparent 70%);pointer-events:none;transform:translate(-50%,-50%);top:50%;left:50%;z-index:0;transition:left 0.15s ease,top 0.15s ease;will-change:left,top;"></div>

  <div style="position:relative;z-index:1;text-align:center;max-width:780px;">
    <p style="font-size:11px;letter-spacing:0.25em;text-transform:uppercase;color:rgba(255,255,255,0.38);margin:0 0 24px;font-family:'Geist','DM Sans',sans-serif;">Vanta Tech · Next-gen performance</p>

    <h1 style="font-family:'Geist','DM Sans',sans-serif;font-size:clamp(48px,7vw,88px);font-weight:700;line-height:1.05;margin:0 0 24px;color:#fff;">
      {{ section.settings.heading_line1 | default: "Engineered for" }}<br>
      <span style="background:linear-gradient(135deg,#0066FF 0%,#00D4FF 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">{{ section.settings.heading_line2 | default: "the Future." }}</span>
    </h1>

    <p style="font-size:16px;color:rgba(255,255,255,0.48);max-width:480px;margin:0 auto 40px;line-height:1.7;font-family:'Geist','DM Sans',sans-serif;">{{ section.settings.subheading | default: "Performance hardware built for those who won't compromise." }}</p>

    {%- if section.settings.image -%}
      <div style="margin:0 auto 48px;max-width:420px;">
        <img src="{{ section.settings.image | image_url: width: 840 }}" alt="{{ section.settings.heading_line1 }}" style="width:100%;height:auto;object-fit:contain;filter:drop-shadow(0 0 60px rgba(0,102,255,0.45)) drop-shadow(0 0 120px rgba(0,212,255,0.12));display:block;">
      </div>
    {%- endif -%}

    <div style="display:flex;gap:12px;align-items:center;justify-content:center;flex-wrap:wrap;">
      <a href="/collections/all" style="background:#0066FF;color:#fff;text-decoration:none;padding:15px 36px;border-radius:100px;font-size:14px;font-weight:600;font-family:'Geist','DM Sans',sans-serif;letter-spacing:0.01em;transition:background 0.2s;">Shop Now →</a>
      <a href="/pages/specs" style="border:1px solid rgba(255,255,255,0.25);color:#fff;background:transparent;text-decoration:none;padding:14px 32px;border-radius:100px;font-size:14px;font-family:'Geist','DM Sans',sans-serif;transition:border-color 0.2s;">View Specs</a>
    </div>
  </div>

  <script>
  (function(){
    var glow = document.querySelector('.vanta-glow');
    var hero = glow && glow.closest('section');
    if (!glow || !hero) return;
    hero.addEventListener('mousemove', function(e){
      var r = hero.getBoundingClientRect();
      glow.style.left = (e.clientX - r.left) + 'px';
      glow.style.top  = (e.clientY - r.top)  + 'px';
    });
  })();
  </script>
</section>

{% schema %}
{
  "name": "Main Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product device image"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading line 1",
      "default": "Engineered for"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading line 2",
      "default": "the Future."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Performance hardware built for those who won't compromise."
    }
  ],
  "presets": [
    {
      "name": "Main Banner"
    }
  ]
}
{% endschema %}