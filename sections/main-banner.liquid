{% comment %}
  VANTA Tech — Main Banner
  Dark animated hero with CSS gradient glows
{% endcomment %}

<style>
  .vanta-hero {
    position: relative;
    min-height: 100vh;
    background: #050510;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .vanta-hero__glow-container {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .vanta-hero__glow {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }

  .vanta-hero__glow--1 {
    width: 600px;
    height: 600px;
    top: 10%;
    left: 20%;
    background: radial-gradient(circle, rgba(0,102,255,0.18) 0%, transparent 70%);
    animation: vanta-glow1 8s ease-in-out infinite alternate;
  }

  .vanta-hero__glow--2 {
    width: 400px;
    height: 400px;
    top: 50%;
    right: 15%;
    background: radial-gradient(circle, rgba(0,212,255,0.1) 0%, transparent 70%);
    animation: vanta-glow2 6s ease-in-out 2s infinite alternate;
  }

  .vanta-hero__glow--3 {
    width: 800px;
    height: 800px;
    bottom: -20%;
    left: 40%;
    background: radial-gradient(circle, rgba(0,66,37,0.06) 0%, transparent 70%);
    animation: vanta-glow3 10s ease-in-out 4s infinite alternate;
  }

  @keyframes vanta-glow1 {
    from { transform: translate(0, 0); }
    to { transform: translate(40px, -30px); }
  }

  @keyframes vanta-glow2 {
    from { transform: translate(0, 0); }
    to { transform: translate(-30px, 40px); }
  }

  @keyframes vanta-glow3 {
    from { transform: translate(0, 0); }
    to { transform: translate(20px, 20px); }
  }

  .vanta-hero__content {
    position: absolute;
    top: 50%;
    left: 60px;
    transform: translateY(-50%);
    z-index: 5;
    max-width: 700px;
  }

  .vanta-hero__eyebrow {
    font-family: 'Geist Mono', monospace;
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.3);
    text-transform: uppercase;
    margin-bottom: 1.2rem;
  }

  .vanta-hero__heading {
    margin: 0;
    padding: 0;
  }

  .vanta-hero__heading-line {
    font-family: 'Geist', sans-serif;
    font-weight: 900;
    font-size: clamp(4rem, 7vw, 7.5rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: white;
    margin: 0;
    opacity: 0;
    transform: translateY(40px);
    animation: forge-fade-up 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .vanta-hero__heading-line:nth-child(1) {
    animation-delay: 0.1s;
  }

  .vanta-hero__heading-line:nth-child(2) {
    animation-delay: 0.2s;
  }

  .vanta-hero__heading-line:nth-child(3) {
    animation-delay: 0.3s;
    background: linear-gradient(135deg, #0066FF, #00D4FF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  @keyframes forge-fade-up {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .vanta-hero__specs {
    margin-top: 2.4rem;
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .vanta-hero__spec {
    font-family: 'Geist Mono', monospace;
    font-weight: 500;
    font-size: 13px;
    color: rgba(255, 255, 255, 0.35);
  }

  .vanta-hero__spec-separator {
    color: rgba(255, 255, 255, 0.15);
  }

  .vanta-hero__buttons {
    margin-top: 3.2rem;
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
  }

  .vanta-hero__button {
    font-family: 'Geist', sans-serif;
    font-weight: 700;
    font-size: 15px;
    border-radius: 100px;
    padding: 14px 32px;
    text-decoration: none;
    display: inline-block;
    transition: all 0.2s ease;
    cursor: pointer;
    border: none;
  }

  .vanta-hero__button--primary {
    background: #0066FF;
    color: white;
  }

  .vanta-hero__button--primary:hover {
    box-shadow: 0 0 30px rgba(0, 102, 255, 0.45);
  }

  .vanta-hero__button--ghost {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: white;
  }

  .vanta-hero__button--ghost:hover {
    border-color: rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.04);
  }

  .vanta-hero__image-container {
    position: absolute;
    right: 8%;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    max-width: 280px;
  }

  .vanta-hero__image {
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 0 40px rgba(0, 102, 255, 0.5));
    animation: forge-breathe 4s ease infinite;
  }

  @keyframes forge-breathe {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.02); }
  }

  @media (max-width: 1024px) {
    .vanta-hero__content {
      left: 40px;
      max-width: 500px;
    }

    .vanta-hero__image-container {
      right: 5%;
      max-width: 220px;
    }
  }

  @media (max-width: 768px) {
    .vanta-hero__content {
      position: relative;
      top: auto;
      left: 0;
      transform: none;
      padding: 0 24px;
      margin-top: 20vh;
    }

    .vanta-hero__image-container {
      position: relative;
      right: auto;
      top: auto;
      transform: none;
      margin: 4rem auto 0;
      max-width: 240px;
    }

    .vanta-hero__specs {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.8rem;
    }

    .vanta-hero__spec-separator {
      display: none;
    }

    .vanta-hero__buttons {
      flex-direction: column;
    }

    .vanta-hero__button {
      width: 100%;
      text-align: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .vanta-hero__glow {
      animation: none;
    }

    .vanta-hero__image {
      animation: none;
    }

    .vanta-hero__heading-line {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>

<section class="vanta-hero">
  <div class="vanta-hero__glow-container">
    <div class="vanta-hero__glow vanta-hero__glow--1"></div>
    <div class="vanta-hero__glow vanta-hero__glow--2"></div>
    <div class="vanta-hero__glow vanta-hero__glow--3"></div>
  </div>

  <div class="vanta-hero__content">
    <div class="vanta-hero__eyebrow">VANTA TECHNOLOGY</div>
    
    <h1 class="vanta-hero__heading">
      <div class="vanta-hero__heading-line" data-forge-split="chars" data-forge-split-anim="wave">
        {{ section.settings.heading_line1 | default: 'Engineered' }}
      </div>
      <div class="vanta-hero__heading-line">
        {{ section.settings.heading_line2 | default: 'Without' }}
      </div>
      <div class="vanta-hero__heading-line">
        {{ section.settings.heading_line3 | default: 'Compromise.' }}
      </div>
    </h1>

    <div class="vanta-hero__specs">
      <span class="vanta-hero__spec">48hr battery</span>
      <span class="vanta-hero__spec-separator">·</span>
      <span class="vanta-hero__spec">IP68 rated</span>
      <span class="vanta-hero__spec-separator">·</span>
      <span class="vanta-hero__spec">0.3s wake</span>
    </div>

    <div class="vanta-hero__buttons">
      {%- if section.settings.button_label != blank -%}
        <a 
          href="{{ section.settings.button_link | default: '#' }}" 
          class="vanta-hero__button vanta-hero__button--primary"
          data-forge-magnet="0.2"
        >
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
      
      {%- if section.settings.button2_label != blank -%}
        <a 
          href="{{ section.settings.button2_link | default: '#' }}" 
          class="vanta-hero__button vanta-hero__button--ghost"
          data-forge-magnet="0.2"
        >
          {{ section.settings.button2_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.image -%}
    <div class="vanta-hero__image-container">
      {{
        section.settings.image
        | image_url: width: 560
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          width: section.settings.image.width,
          height: section.settings.image.height,
          class: 'vanta-hero__image',
          alt: section.settings.image.alt | default: 'VANTA Technology Product'
      }}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Main Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product Image"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading Line 1",
      "default": "Engineered"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading Line 2",
      "default": "Without"
    },
    {
      "type": "text",
      "id": "heading_line3",
      "label": "Heading Line 3 (Gradient)",
      "default": "Compromise."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary Button Label",
      "default": "Explore Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "button2_label",
      "label": "Secondary Button Label",
      "default": "View Specs"
    },
    {
      "type": "url",
      "id": "button2_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "Main Banner"
    }
  ]
}
{% endschema %}